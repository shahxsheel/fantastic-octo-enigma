# Supabase Configuration
# Copy this file to .env and fill in your values

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Vehicle Configuration
VEHICLE_ID=VEHICLE-001
VEHICLE_NAME="My Vehicle"

# YOLO Detection (Phone/Drinking detection)
ENABLE_YOLO=true

# Gyro sensor serial port (default: /dev/ttyACM0)
GYRO_SERIAL_PORT=/dev/ttyACM0
# Force fake GPS/Gyro data even if hardware is connected (0 or 1)
USE_FAKE_GPS=0
USE_FAKE_GYRO=0

# Head-direction estimate in the Pi runtime (0 or 1)
ENABLE_HEAD_DIRECTION=1
HEAD_DIRECTION_EVERY_N=4

# Camera
CAMERA_INDEX=0
INFER_WIDTH=256
INFER_HEIGHT=256

# Low-light gamma correction
LOW_LIGHT=1

# Run without GUI (SSH/headless)
# HEADLESS=1
